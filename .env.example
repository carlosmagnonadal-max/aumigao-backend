DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

JWT_SECRET="aumigao-super-secret-key-change-me"
SIGNED_UPLOAD_SECRET=
SIGNED_UPLOAD_TTL_SECONDS=600

# Resolucao de tenant estrita (spec §6.4): "true" desliga o fallback silencioso
# para o tenant padrao; rotas sensiveis passam a exigir tenant (400 TENANT_REQUIRED).
# Default "false" mantem o comportamento de beta.
STRICT_TENANT_RESOLUTION=false

ADMIN_EMAIL="admin@aumigao.com"
ADMIN_PASSWORD="change-me"

SUPER_ADMIN_EMAIL="superadmin@aumigao.com"
SUPER_ADMIN_PASSWORD="change-me"

DB_NAME="aumigao"

STRIPE_API_KEY="sk_test_change_me"
PAYMENT_MODE=asaas_sandbox
ASAAS_SANDBOX_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_SANDBOX_DEFAULT_CPF_CNPJ=
ASAAS_SANDBOX_API_KEY=
